# 🍳 智能厨房助手 - 环境变量配置示例
# 复制此文件为 .env 并填入您的实际配置

# ===========================================
# 🔑 智谱AI API配置
# ===========================================

# 智谱AI API密钥（必需）
# 获取地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipuai_api_key_here

# ===========================================
# 🌐 应用配置
# ===========================================

# 应用运行端口（可选，默认8501）
PORT=8501

# 应用标题（可选）
APP_TITLE=智能厨房助手

# ===========================================
# 🔧 调试配置
# ===========================================

# 调试模式（可选，默认False）
DEBUG=False

# 日志级别（可选，默认INFO）
LOG_LEVEL=INFO

# ===========================================
# 🎯 功能配置
# ===========================================

# 启用语音功能（可选，默认True）
ENABLE_AUDIO=True

# 语音识别语言（可选，默认zh-CN）
SPEECH_LANGUAGE=zh-CN

# TTS语音类型（可选，默认zh-CN-XiaoxiaoNeural）
TTS_VOICE=zh-CN-XiaoxiaoNeural

# ===========================================
# 📊 性能配置
# ===========================================

# API调用超时时间（秒，可选，默认30）
API_TIMEOUT=30

# 最大并发请求数（可选，默认5）
MAX_CONCURRENT_REQUESTS=5

# ===========================================
# 💡 使用说明
# ===========================================

# 1. 复制此文件为 .env
# 2. 将 ZHIPU_API_KEY 替换为您的实际API密钥
# 3. 根据需要调整其他配置
# 4. 本地运行时，应用会自动读取此文件

# 云端部署时，需要在部署平台设置环境变量：
# - GitHub Pages: 仓库Settings → Secrets
# - Streamlit Cloud: 应用设置 → Secrets

# 注意：此文件不包含敏感信息，可以提交到版本控制
# 实际API密钥请保存在 .env 文件中，并添加到 .gitignore